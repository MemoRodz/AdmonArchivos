@page "/image-convert"
@inject IJSRuntime JS

<PageTitle>Conversor de Imágenes</PageTitle>

<h3>Conversión de imágenes (JPG, PNG, ICO)</h3>

<div class="mb-3">
    <InputFile accept=".png,.jpg,.jpeg,.ico" OnChange="OnInputFileChange" />
</div>

@if (!string.IsNullOrEmpty(PreviewImage))
{
    <div class="mb-3">
        <img src="@PreviewImage" style="max-width: 300px; max-height:200px;" alt="Imagen previa" />
    </div>
}

<div class="mb-3">
    <select class="form-select w-auto mb-2" @bind="TargetFormat">
        <option value="png">PNG</option>
        <option value="jpg">JPG</option>
        <option value="ico">ICO</option>
    </select>
    <button class="btn btn-primary ms-2" @onclick="ConvertImage">Convertir</button>
</div>

@if (!string.IsNullOrWhiteSpace(DownloadUrl))
{
    <div class="mt-2">
        <a href="@DownloadUrl" download="convertida.@TargetFormat" class="btn btn-success">Descargar convertida</a>
    </div>
}
