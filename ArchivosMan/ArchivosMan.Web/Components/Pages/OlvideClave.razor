@page "/olvide-clave"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using ArchivosMan.BLL
@using ArchivosMan.BLL.Interfaces

<PageTitle>Olvidé mi contraseña</PageTitle>

<h3>Olvidé mi contraseña</h3>

<EditForm Model="@modelo" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (!string.IsNullOrEmpty(MensajeError))
    {
        <div class="alert alert-danger">@MensajeError</div>
    }
    @if (!string.IsNullOrEmpty(MensajeOk))
    {
        <div class="alert alert-success">@MensajeOk</div>
    }

    <div class="mb-3">
        <label class="form-label">Correo registrado</label>
        <InputText class="form-control" @bind-Value="modelo.Correo" />
        <ValidationMessage For="@(() => modelo.Correo)" />
    </div>
    <button class="btn btn-primary" type="submit">Restablecer contraseña</button>
</EditForm>