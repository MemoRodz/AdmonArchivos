@page "/convertidor"

<PageTitle>Convertidor</PageTitle>

<h3>Convertidores</h3>

<div class="p-3 border rounded shadow-sm">
    <h4>Convertir cantidad en letra, pesos mexicanos.</h4>
    <!-- Input para valorMonto -->
    <div class="mb-2 d-flex align-items-center gap-2">
        <input type="number" step="0.01" class="form-control w-25"
               @bind="valorMonto"
               @onkeydown="ConvertNumLetraOnKeyDownHandler"
               placeholder="Monto"
               onfocus="this.select()" />
        <!-- Botón para convertir -->
        <button class="btn btn-primary" @onclick="NumeroLetra">
            A letras
        </button>
        <!-- Checkbox -->
        <div class="form-check ms-3">
            <input class="form-check-input" type="checkbox"
                   @bind="mostrarDecimales" />
            <label class="form-check-label">
                Con Decimales
            </label>
        </div>
        <!-- Botón de limpiar a la derecha -->
        <button class="btn btn-outline-danger" @onclick="LimpiarControlesNumLetras">
            Limpiar
        </button>
    </div>
    <!-- Cuadro de texto para mostrar valorEnLetras -->
    <div>
        <textarea class="form-control" rows="3" readonly>@valorEnLetras</textarea>
    </div>
</div>
<hr />
<div class="p-3 border rounded shadow-sm">
    <div class="mb-2 d-flex align-items-center gap-2">
        <h4>Convertir Temperaturas Celsius / Fahrenheit.</h4>
        <div class="mb-2 d-flex align-items-center gap-2 flex-wrap">
            <!-- Input numérico -->
            <input type="number" step="0.01"
                   class="form-control"
                   style="max-width: 180px;"
                   @bind="temperaturaEntrada"
                   placeholder="Valor"
                   onfocus="this.select()" />

            <!-- Selección de unidad de entrada -->
            <select class="form-select"
                    style="max-width: 150px;"
                    @bind="unidadEntrada">
                <option value="C">Celsius (°C)</option>
                <option value="F">Fahrenheit (°F)</option>
            </select>

            <!-- Botón convertir -->
            <button class="btn btn-primary" @onclick="ConvertirTemperatura">
                Convertir
            </button>

            <!-- Botón limpiar -->
            <button class="btn btn-outline-danger" @onclick="LimpiarTemperatura">
                Limpiar
            </button>
        </div>

        <div class="mt-2">
            <label class="form-label">Resultado</label>
            <input class="form-control"
                   style="max-width: 260px;"
                   readonly
                   value="@ObtenerResultadoFormateado()" />
        </div>
    </div>
</div>
<hr />
<div class="p-3 border rounded shadow-sm">
    <div class="mb-2 d-flex align-items-center gap-2">
        <input type="text" class="form-control w-25"
               @bind="entrada"
               @onkeydown="OnKeyDownHandlerCadenaEncriptada"
               placeholder="Cadena para encriptar"
               onfocus="this.select()" />
        <button class="btn btn-outline-primary" @onclick="ObtenerCadena">
            Encriptar
        </button>
        <button class="btn btn-outline-danger" @onclick="LimpiarCadena">
            Limpiar
        </button>
        <input type="text" class="form-control w-25"
               @bind="entrada"
               @onkeydown="OnKeyDownHandlerCadenaDesencriptada"
               placeholder="Cadena encriptada"
               onfocus="this.select()" />
        <button class="btn btn-outline-primary" @onclick="ResolverCadena">
            Desencriptar
        </button>
    </div>
    <div>
        <textarea class="form-control" rows="3" readonly>@salida</textarea>
    </div>
</div>