@inject ArchivosMan.BLL.Services.AuthState Auth
@inject ArchivosMan.BLL.Interfaces.IMenuService MenuService
@inject NavigationManager Nav
@using ArchivosMan.BLL.DTO
@implements IDisposable

<div class="nav-scrollable">
    <ul class="nav flex-column">

        <li class="nav-item px-3">
            <NavLink class="nav-link" href="/" title="Inicio" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>Inicio
            </NavLink>
        </li>

        @if (!Auth.EstaAutenticado)
        {
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="/login" title="Login">
                    <span class="bi bi-login-fill-nav-menu" aria-hidden="true"></span>Login
                </NavLink>
            </li>
        }
        else if (_menuItems != null)
        {
            @foreach (var menu in _menuItems)
            {
                var collapseId = $"menu_{menu.IdMenu}";
                var abierto = MenuAbierto(collapseId);
                if (menu.Hijos.Any())
                {
                    <li class="nav-item">
                        <button type="button"
                                title="@menu.Descripcion"
                                class="nav-link nav-parent d-flex justify-content-between align-items-center w-100 text-start"
                                @onclick="() => ToggleMenu(collapseId)">
                            @if (!string.IsNullOrWhiteSpace(menu.Icono))
                            {
                                <span class="@menu.Icono" aria-hidden="true"></span>
                                @:
                            }
                            @menu.Descripcion
                            <span class="fa-solid fa-chevron-down small chevron-icon @(abierto ? "abierto" : "")"></span>
                        </button>

                        <div class="collapse @(abierto ? "show" : "")" id="@collapseId">
                            <ul class="nav flex-column ms-2">
                                @foreach (var submenu in menu.Hijos)
                                {
                                    <li class="nav-item px-3">
                                        <NavLink class="nav-link ms-3" href="@NormalizarRuta(submenu.Url)" Match="NavLinkMatch.Prefix" title="@submenu.Descripcion">
                                            @if (!string.IsNullOrWhiteSpace(submenu.Icono))
                                            {
                                                <span class="@submenu.Icono" aria-hidden="true"></span>
                                                @:
                                            }
                                            @submenu.Descripcion
                                        </NavLink>
                                    </li>
                                }
                            </ul>
                        </div>
                    </li>
                }
                else
                {
                    <li class="nav-item px-3">
                        <NavLink class="nav-link" href="@NormalizarRuta(menu.Url)" Match="NavLinkMatch.Prefix">
                            @if (!string.IsNullOrWhiteSpace(menu.Icono))
                            {
                                <span class="@menu.Icono" aria-hidden="true"></span>
                                @:
                            }
                            @menu.Descripcion
                        </NavLink>
                    </li>
                }
            }
        }

        
        <li class="nav-item">
            <button type="button"
                    title="Utilerías"
                    class="nav-link nav-parent d-flex justify-content-between align-items-center w-100 text-start"
                    @onclick="() => ToggleMenu(menuFijo)">
                <span class="fa-solid fa-computer" aria-hidden="true"></span>Utilerías
                <span class="fa-solid fa-chevron-down small chevron-icon @(MenuAbierto(menuFijo) ? "abierto" : "")"></span>
            </button>
            <div class="collapse @(MenuAbierto("utilerias") ? "show" : "")">
                <ul class="nav flex-column ms-2">
                    <li class="nav-item px-3">
                        <NavLink class="nav-link" href="/image-convert" title="Convertir Imágenes" Match="NavLinkMatch.Prefix">
                            <span class="fa-solid fa-file-image me-2" aria-hidden="true"></span> Convertir Imágenes
                        </NavLink>
                    </li>
                    <li class="nav-item px-3">
                        <NavLink class="nav-link" href="/convertidor" title="Convertidores" Match="NavLinkMatch.Prefix">
                            <span class="fa-solid fa-otter me-2" aria-hidden="true"></span> Convertidor
                        </NavLink>
                    </li>
                    <li>
                        <NavLink class="nav-link" href="/conversor-horario"
                                 title="Conversor de Horario" Match="NavLinkMatch.Prefix">
                            <span class="fa-solid fa-globe me-2" aria-hidden="true"></span>
                            Horario Mundial
                        </NavLink>
                    </li>
                    <li class="nav-item px-3">
                        <NavLink class="nav-link" href="/counter" title="Contador" Match="NavLinkMatch.Prefix">
                            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Contador
                        </NavLink>
                    </li>
                    <li class="nav-item px-3">
                        <NavLink class="nav-link" href="/weather" title="Clima" Match="NavLinkMatch.Prefix">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Clima
                        </NavLink>
                    </li>
                </ul>
            </div>
        </li>


    </ul>
</div>

@code {
    private List<MenuItemDto>? _menuItems;
    private string? _currentPath;
    private HashSet<string> _menusAbiertos = new();
    private const string menuFijo = "utilerias";

    protected override async void OnInitialized()
    {
        Auth.OnChange += AuthStateChanged;
        Nav.LocationChanged += OnLocationChanged;

        ActualizarRutaActual();
        // Lazy load inicial: si ya hay usuario y aún no hay menú, cargarlo
        if (Auth.EstaAutenticado && _menuItems == null)
        {
            await CargarMenu();
        }
        ExpandirMenuActual();
    }

    private async Task CargarMenu()
    {

        if (Auth.UsuarioActual == null || !Auth.UsuarioActual.RolId.HasValue)
        {
            _menuItems = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var rolId = Auth.UsuarioActual.RolId.Value;
        _menuItems = await MenuService.ObtenerMenuPorRolAsync(rolId);

        ExpandirMenuActual();

        await InvokeAsync(StateHasChanged);
    }

    private void AuthStateChanged()
    {
        _ = CargarMenu();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ActualizarRutaActual();
        ExpandirMenuActual();
        InvokeAsync(StateHasChanged);
    }

    private void ActualizarRutaActual()
    {
        _currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        if (_currentPath == "/")
            _currentPath = "/";
    }

    private void ToggleMenu(string menuId)
    {
        if (_menusAbiertos.Contains(menuId))
            _menusAbiertos.Remove(menuId);
        else
        {
            _menusAbiertos.Clear();
            _menusAbiertos.Add(menuId);
        }
    }

    private bool MenuAbierto(string menuId) => _menusAbiertos.Contains(menuId);

    private void ExpandirMenuActual()
    {
        if (string.IsNullOrWhiteSpace(_currentPath))
            return;

        _menusAbiertos.Clear();

        if (_currentPath.StartsWith("/image-convert") ||
            _currentPath.StartsWith("/convertidor") ||
            _currentPath.StartsWith("/counter") ||
            _currentPath.StartsWith("/weather"))
        {
            _menusAbiertos.Add("utilerias");
        }

        if (_menuItems == null)
            return;

        foreach (var menu in _menuItems.Where(m => m.Hijos.Any()))
        {
            var collapseId = $"menu_{menu.IdMenu}";

            if (menu.Hijos.Any(h => _currentPath.StartsWith(NormalizarRuta(h.Url), StringComparison.OrdinalIgnoreCase)))
            {
                _menusAbiertos.Add(collapseId);
                return;
            }
        }
    }

    private string NormalizarRuta(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return "/";

        return url.StartsWith("/") ? url : "/" + url;
    }

    public void Dispose()
    {
        Auth.OnChange -= AuthStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}

