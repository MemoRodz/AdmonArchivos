@inherits LayoutComponentBase
@inject ArchivosMan.BLL.Services.AuthState Auth
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar @(MenuVisible ? "" : "sidebar-oculto")">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <!-- Botón toggle del menú -->
            <button class="btn btn-sm btn-outline-secondary me-2"
                    type="button"
                    title="@(MenuVisible ? "Ocultar menú" : "Mostrar menú")"
                    @onclick="ToggleSidebar">
                <span class="fa-solid fa-bars"></span>
            </button>

            <NavLink href="/portfolio" class="nav-link" ActiveClass="active">
                <span class="fa-solid fa-business-time"></span> Portafolio
            </NavLink>

            <NavLink href="/contactame" class="nav-link ms-3" ActiveClass="active">
                <span class="fa-solid fa-envelope"></span> Contáctame
            </NavLink>

            <div class="ms-auto d-flex align-items-center">
                @if (Auth.EstaAutenticado && Auth.UsuarioActual is not null)
                {
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            <span class="me-2">Hola, @Auth.UsuarioActual.Nombre</span>
                            @if (!string.IsNullOrWhiteSpace(Auth.UsuarioActual.UrlFoto))
                            {
                                <img src="@Auth.UsuarioActual.UrlFoto"
                                     style="width:28px;height:28px;border-radius:50%;object-fit:cover;" />
                            }
                            else
                            {
                                <span class="fa-regular fa-circle-user fs-5"></span>
                            }
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="dropdown-header small text-muted">
                                @Auth.UsuarioActual.Correo
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item" href="/perfil">
                                    <span class="fa-regular fa-id-badge me-2"></span> Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/cambiar-clave">
                                    <span class="fa-solid fa-key me-2"></span> Cambiar contraseña
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <button class="dropdown-item text-danger" type="button" @onclick="CerrarSesion">
                                    <span class="fa-solid fa-right-from-bracket me-2"></span> Cerrar sesión
                                </button>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <NavLink class="nav-link ms-3" href="/login">
                        <span class="fa-regular fa-id-card" aria-hidden="true"></span> Login
                    </NavLink>
                }
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Se ha producido un error no controlado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool MenuVisible { get; set; } = true;
    private bool IsLoading { get; set; } = true;

    private void ToggleSidebar()
    {
        MenuVisible = !MenuVisible;
    }

    private void CerrarSesion()
    {
        Console.WriteLine("Cerrando sesión...");
        Auth.CerrarSesion();
        Nav.NavigateTo("/login", forceLoad: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500);
            IsLoading = false;
            StateHasChanged();
        }
    }
}
